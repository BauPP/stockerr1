# ----------------------------------------------------------------------------
# API Gateway — variables de entorno
# ----------------------------------------------------------------------------
# Copia este archivo como .env y ajusta los valores según tu entorno.
# En docker-compose.yml estas variables ya vienen seteadas con los nombres
# de servicio internos del compose (http://auth-service:3002, etc.).
# ----------------------------------------------------------------------------

# Puerto en el que escucha el gateway
PORT=3000

# URLs de los microservicios (ver docker-compose.yml para los puertos canónicos)
AUTH_SERVICE_URL=http://localhost:3002
PRODUCT_SERVICE_URL=http://localhost:3001
CATEGORY_SERVICE_URL=http://localhost:3003
USER_SERVICE_URL=http://localhost:3004
INVENTORY_SERVICE_URL=http://localhost:3005
AUDIT_SERVICE_URL=http://localhost:3006
